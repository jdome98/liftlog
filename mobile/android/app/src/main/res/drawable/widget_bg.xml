<?xml version="1.0" encoding="utf-8"?>
<!--
  Widget container background. The 28dp corner radius matches the standard
  Material You / Android 12+ launcher widget clip — without it, the launcher
  rounds the widget but our orange stroke stays rectangular and gets clipped
  off at the corners.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android" android:shape="rectangle">
    <solid android:color="@color/ss_bg_elevated" />
    <stroke android:width="2dp" android:color="@color/ss_accent" />
    <corners android:radius="28dp" />
</shape>
